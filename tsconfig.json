{
  "compilerOptions": {
    "target": "esnext",                          
    "module": "esnext",
    "moduleResolution": "node",                     
    "noEmitOnError": true,
    "lib": ["es2017", "dom"],                            
    "strict": true,  
    "esModuleInterop": true,                 
    "outDir": "out-tsc",
    "rootDir": "./",
    "noImplicitAny": false,
    "skipLibCheck": true,
    "declaration": true
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["node_modules"]
}