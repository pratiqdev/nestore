{
  "compilerOptions": {
    "target": "es6",                   
    "module": "es2020",
    "moduleResolution": "node",                     
    "noEmitOnError": true,
    "lib": ["es5", "es6", "dom"],                            
    "strict": true,  
    "esModuleInterop": true,                 
    "rootDir": "./",
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": ["./src/*.ts"],
  "exclude": [
    "node_modules",
    "**d.ts",
  ]
}